# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use the PUBLISHABLE (anon) key — NOT the secret/service_role key
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key-here
# Optional alias (same value as ANON_KEY)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
# Server-only secret key — never expose in browser (no NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# AI Providers (at least one required for verification)
OPENAI_API_KEY=your-openai-key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:4028
